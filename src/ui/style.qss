/* ── Global ── */
* {
    font-family: "NimbusMonoPS", "Maple Mono", "JetBrains Mono", monospace;
    font-size: 10pt;
    color: #c8c8c8;
    outline: none;
}

QMainWindow {
    background-color: #0a0a0a;
}

QWidget {
    background-color: #0a0a0a;
}

/* ── Central widget ── */
QWidget#centralWidget {
    background: #0a0a0a;
    padding: 6px;
}

/* ── Splitter ── */
QSplitter#mainSplitter {
    background: #0a0a0a;
    spacing: 6px;
}

QSplitter#mainSplitter::handle:horizontal {
    background: transparent;
    width: 6px;
}

/* ── Sidebar zone ── */
QFrame#sidebar {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    margin: 0px 3px 0px 0px;
}

QLabel#sidebarTitle {
    background: transparent;
    color: #333333;
    font-size: 8pt;
    font-weight: bold;
    letter-spacing: 2px;
    padding: 12px 10px 6px 10px;
}

QFrame#sidebarSeparator {
    background: #222222;
    border: none;
    max-height: 1px;
    margin: 0px 8px;
}

QListWidget {
    background: transparent;
    color: #555555;
    border: none;
    border-radius: 8px;
    padding: 2px;
}

QListWidget::item {
    padding: 4px 10px;
    border-radius: 0px;
    border-left: 2px solid transparent;
    margin: 1px 4px;
}

QListWidget::item:hover {
    background: #1a1a1a;
    color: #c8c8c8;
    padding-left: 18px;
    border-radius: 4px;
}

QListWidget::item:selected {
    background: #ffffff;
    color: #000000;
    border-left: 2px solid #ffffff;
    padding-left: 18px;
    border-radius: 4px;
}

/* ── File list zone ── */
QTreeView#fileList {
    background: #111111;
    color: #c8c8c8;
    border: 1px solid #222222;
    border-radius: 8px;
    alternate-background-color: #111111;
    show-decoration-selected: 1;
    padding: 2px;
}

QTreeView#fileList::item {
    padding: 3px 4px;
    border-left: 2px solid transparent;
    border-radius: 0px;
    margin: 0px 2px;
}

QTreeView#fileList::item:hover {
    background: #1a1a1a;
    color: #c8c8c8;
    padding-left: 18px;
    border-radius: 4px;
}

QTreeView#fileList::item:selected {
    background: #ffffff;
    color: #000000;
    border-left: 2px solid #ffffff;
    padding-left: 18px;
    border-radius: 4px;
}

QTreeView#fileList::item:selected:hover {
    background: #e8e8e8;
    color: #000000;
    border-left: 2px solid #ffffff;
}

/* ── Preview panel zone ── */
QWidget#previewPanel {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    margin: 0px 0px 0px 3px;
}

/* ── Column headers ── */
QHeaderView {
    background: transparent;
    border: none;
    border-radius: 8px;
}

QHeaderView::section {
    background: #111111;
    color: #333333;
    border: none;
    border-bottom: 1px solid #1e1e1e;
    border-right: 1px solid #1e1e1e;
    padding: 4px 8px;
    font-size: 8pt;
    font-weight: bold;
    letter-spacing: 1px;
}

QHeaderView::section:first {
    border-top-left-radius: 8px;
}

QHeaderView::section:last {
    border-right: none;
    border-top-right-radius: 8px;
}

QHeaderView::section:hover {
    background: #1a1a1a;
    color: #888888;
}

/* ── Toolbar ── */
QToolBar {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    padding: 4px 8px;
    margin: 6px 6px 3px 6px;
    spacing: 4px;
    min-height: 36px;
}

QToolBar::separator {
    background: #222222;
    width: 1px;
    margin: 4px 4px;
}

QToolBar QToolButton {
    background: transparent;
    color: #555555;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 3px 10px;
    margin: 0px 2px;
}

QToolBar QToolButton:hover {
    background: #1a1a1a;
    color: #c8c8c8;
    border-color: #444444;
}

QToolBar QToolButton:pressed {
    background: #222222;
    color: #ffffff;
    border-color: #555555;
}

/* Hidden files button */
QToolBar QToolButton#hiddenButton {
    background: transparent;
    color: #555555;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 3px 10px;
}

QToolBar QToolButton#hiddenButton:checked {
    background: #ffffff;
    color: #000000;
    border-color: #ffffff;
}

QToolBar QToolButton#hiddenButton:hover {
    background: #1a1a1a;
    color: #c8c8c8;
    border-color: #444444;
}

QToolBar QToolButton#hiddenButton:checked:hover {
    background: #e8e8e8;
    color: #000000;
}

/* ── Path bar ── */
QLabel#pathLabel {
    background: transparent;
    color: #444444;
    font-size: 9pt;
    padding: 2px 8px;
}

/* ── Search bar ── */
QLineEdit {
    background: #0f0f0f;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    color: #c8c8c8;
    padding: 3px 8px;
    margin: 0px 2px;
    selection-background-color: #ffffff;
    selection-color: #000000;
}

QLineEdit:focus {
    border-color: #555555;
    background: #111111;
}

/* ── Status bar ── */
QStatusBar {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
    font-size: 8pt;
    padding: 6px 10px;
    margin: 3px 6px 6px 6px;
    min-height: 18px;
}

QStatusBar QLabel {
    color: #333333;
    font-size: 8pt;
    background: transparent;
    padding: 0px;
}

/* ── Scrollbars ── */
QScrollBar:vertical {
    background: transparent;
    width: 5px;
    margin: 4px 2px;
}

QScrollBar::handle:vertical {
    background: #2a2a2a;
    border-radius: 2px;
    min-height: 20px;
}

QScrollBar::handle:vertical:hover {
    background: #444444;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: transparent;
    height: 0px;
}

QScrollBar:horizontal {
    background: transparent;
    height: 5px;
    margin: 2px 4px;
}

QScrollBar::handle:horizontal {
    background: #2a2a2a;
    border-radius: 2px;
    min-width: 20px;
}

QScrollBar::add-line:horizontal,
QScrollBar::sub-line:horizontal,
QScrollBar::add-page:horizontal,
QScrollBar::sub-page:horizontal {
    background: transparent;
    width: 0px;
}

/* ── Context menu ── */
QMenu {
    background: #111111;
    color: #c8c8c8;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    padding: 4px;
}

QMenu::item {
    padding: 5px 24px 5px 12px;
    border-radius: 4px;
    border-left: 2px solid transparent;
}

QMenu::item:selected {
    background: #ffffff;
    color: #000000;
    border-left: 2px solid #ffffff;
    padding-left: 14px;
    border-radius: 4px;
}

QMenu::separator {
    height: 1px;
    background: #1e1e1e;
    margin: 3px 8px;
}

/* ── Dialogs ── */
QDialog {
    background: #111111;
    border: 1px solid #222222;
    border-radius: 8px;
}

QDialog QLabel {
    color: #c8c8c8;
    background: transparent;
}

QInputDialog QLineEdit {
    background: #0a0a0a;
    color: #c8c8c8;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 5px 8px;
}

QInputDialog QPushButton,
QMessageBox QPushButton,
QDialog QPushButton {
    background: #0a0a0a;
    color: #c8c8c8;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    padding: 5px 14px;
    min-width: 60px;
}

QInputDialog QPushButton:hover,
QMessageBox QPushButton:hover,
QDialog QPushButton:hover {
    background: #1a1a1a;
    color: #ffffff;
    border-color: #444444;
}

QInputDialog QPushButton:default,
QMessageBox QPushButton:default,
QDialog QPushButton:default {
    background: #ffffff;
    color: #000000;
    border-color: #ffffff;
}

QInputDialog QPushButton:default:hover,
QMessageBox QPushButton:default:hover,
QDialog QPushButton:default:hover {
    background: #e8e8e8;
    color: #000000;
}

QMessageBox {
    background: #111111;
}

/* ── Progress bar ── */
QProgressBar {
    background: #0a0a0a;
    border: 1px solid #2a2a2a;
    border-radius: 4px;
    color: transparent;
    height: 4px;
    text-align: center;
}

QProgressBar::chunk {
    background: #ffffff;
    border-radius: 3px;
}
